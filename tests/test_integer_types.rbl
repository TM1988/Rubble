// Test new integer type variants (i8, i16, i32) and unsigned types (u8, u16, u32, u64)

write "=== Testing i8 ==="
slot a: i8 = 127
slot b: i8 = -128
write f"i8 max: {a}"
write f"i8 min: {b}"
slot c = a + b
write f"i8 sum: {c}"

write "=== Testing i16 ==="
slot x: i16 = 32767
slot y: i16 = -32768
write f"i16 max: {x}"
write f"i16 min: {y}"

write "=== Testing i32 ==="
slot m: i32 = 2147483647
slot n: i32 = -2147483648
write f"i32 max: {m}"
write f"i32 min: {n}"

write "=== Testing u8 ==="
slot u: u8 = 255
write f"u8 max: {u}"

write "=== Testing u16 ==="
slot v: u16 = 65535
write f"u16 max: {v}"

write "=== Testing u32 ==="
slot w: u32 = 4294967295
write f"u32 max: {w}"

write "=== Testing u64 ==="
slot z: u64 = 18446744073709551615
write f"u64 max: {z}"

write "=== Testing operations ==="
slot i1: i8 = 10
slot i2: i8 = 20
slot sum = i1 + i2
write f"i8 addition: {sum}"

slot j1: i16 = 100
slot j2: i16 = 200
slot sum16 = j1 + j2
write f"i16 addition: {sum16}"

write "=== Testing in blueprints ==="
blueprint SmallNumbers {
    a: i8,
    b: u8,
    c: i16
}

slot nums = build SmallNumbers(a: 42, b: 255, c: 1000)
write f"Blueprint i8: {nums.a}"
write f"Blueprint u8: {nums.b}"
write f"Blueprint i16: {nums.c}"

write "=== Testing in recipes ==="
recipe add_i8(a: i8, b: i8) -> i8 {
    yield a + b
}

recipe add_u32(a: u32, b: u32) -> u32 {
    yield a + b
}

slot result1 = add_i8(50, 60)
write f"Recipe i8 result: {result1}"

slot result2 = add_u32(1000, 2000)
write f"Recipe u32 result: {result2}"

write "ALL INTEGER TYPE TESTS PASSED"
